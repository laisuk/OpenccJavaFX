                </GridPane.margin>
            </Button>
            <Button fx:id="btnExit" mnemonicParsing="false" onMouseClicked="#onBtnExitClicked" prefHeight="20.0" prefWidth="60.0" styleClass="button-secondary" text="Exit" GridPane.columnIndex="2" GridPane.halignment="RIGHT" GridPane.valignment="TOP">
                <GridPane.margin>
                    <Insets />
                </GridPane.margin>
            </Button>
            <Button fx:id="btnOpenFile" mnemonicParsing="false" onMouseClicked="#onBtnOpenFileClicked" prefHeight="20.0" prefWidth="92.0" styleClass="button-secondary" text="Open File" GridPane.halignment="LEFT" GridPane.valignment="TOP">
                <GridPane.margin>
                    <Insets />
                </GridPane.margin>
            </Button>
            <Label fx:id="lblFilename">
                <GridPane.margin>
                    <Insets left="95.0" />
                </GridPane.margin>
                <font>
                    <Font size="14.0" />
                </font>
            </Label>
        </children>
    </GridPane>
    <GridPane styleClass="status-bar" VBox.vgrow="NEVER">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="20.0" prefHeight="30.0" vgrow="NEVER" />
        </rowConstraints>
        <children>
            <HBox alignment="BOTTOM_LEFT" prefHeight="100.0" prefWidth="200.0">
                <children>
                    <Label fx:id="lblStatus" styleClass="status-label" text="OpenccJavaFX">
                        <padding>
                            <Insets right="10.0" />
                        </padding>
                        <HBox.margin>
                            <Insets bottom="15.0" />
                        </HBox.margin>
                    </Label>
                    <ProgressBar fx:id="buildProgressBar" prefWidth="200.0" progress="0.0" styleClass="app-progress" visible="false">
                        <HBox.margin>
                            <Insets bottom="13.0" />
                        </HBox.margin>
                    </ProgressBar>
                </children>
                <GridPane.margin>
                    <Insets top="10.0" />
                </GridPane.margin>
                <padding>
                    <Insets top="5.0" />
                </padding>
            </HBox>
        </children>
    </GridPane>
</VBox>
