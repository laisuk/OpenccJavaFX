                                 <ComboBox fx:id="cbLanguage" prefWidth="150.0">
                                    <HBox.margin>
                                       <Insets left="10.0" />
                                    </HBox.margin>
                                 </ComboBox>
                              </children>
                           </HBox>
                                </children>
                            </GridPane>
                        </children>
                    </AnchorPane>
                </content>
            </Tab>
        </tabs>
    </TabPane>
    <GridPane styleClass="action-bar">
